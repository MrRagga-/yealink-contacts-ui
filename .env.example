APP_NAME=Yealink Contacts Sync
APP_VERSION=0.2.4
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/yealink_contacts
DEV_DATABASE_URL=sqlite:///./yealink_contacts.db
# Generate APP_SECRET_KEY with:
#   openssl rand -hex 32
APP_SECRET_KEY=change-me-to-a-long-random-string
# Generate ENCRYPTION_KEY with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=S4aexYnjREGeQkSQIlPCXSQLgXUhY_GfJ1i1n1a34zg=
DEFAULT_COUNTRY_CODE=DE
LOG_LEVEL=INFO
# Optional: override the public XML base URL if it differs from FRONTEND_ORIGIN
# XML_PUBLIC_BASE_URL=http://localhost:8000
SYNC_HTTP_TIMEOUT=20
# Optional: comma-separated CIDR list of reverse proxies that may set X-Forwarded-For
# TRUSTED_PROXY_CIDRS=172.16.0.0/12,10.0.0.0/8
# Optional emergency override for the persisted admin/XML allowlists.
# Localhost is always allowed; set these to `0.0.0.0/0,::/0` to recover from a lockout.
# ADMIN_ALLOWED_CIDRS_OVERRIDE=0.0.0.0/0,::/0
# XML_ALLOWED_CIDRS_OVERRIDE=0.0.0.0/0,::/0
# Optional: override the signed admin session cookie name and lifetime
# SESSION_COOKIE_NAME=yealink_admin_session
# SESSION_MAX_AGE_SECONDS=43200
# Optional: override WebAuthn relying-party settings if they differ from FRONTEND_ORIGIN / APP_NAME
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_RP_NAME=Yealink Contacts Sync
# WEBAUTHN_RP_ORIGIN=http://localhost:5173
VITE_GITHUB_URL=https://github.com/MrRagga-/yealink-contacts-ui
VITE_GITHUB_ISSUES_URL=https://github.com/MrRagga-/yealink-contacts-ui/issues
VITE_DOCKERHUB_URL=https://hub.docker.com/r/mrragga/yealink-contacts-ui
VITE_SUPPORT_URL=https://github.com/MrRagga-/yealink-contacts-ui/blob/main/SUPPORT.md
